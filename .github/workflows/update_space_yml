name: Update Hugging Face Space

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3
      
      - name: Setup Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'
      
      - name: Install dependencies
        run: |
          pip install -r requirements.txt
      
      - name: Process data
        run: |
          python -c "from data_processing import load_and_process; load_and_process()"
      
      - name: Deploy to Hugging Face
        uses: huggingface/space-uploader@v1
        with:
          space_id: votre-username/tinder-speed-dating
          token: ${{ secrets.HF_TOKEN }}
          folder: .